# ─────────────────────────────────────────────────────────────────────────────
# rgstr — пример конфигурации
# Скопируйте этот файл в .env и заполните нужные значения:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────


# ── Сервер ────────────────────────────────────────────────────────────────────

# Адрес и порт для прослушивания.
# Примеры: ":5000"  "0.0.0.0:5000"  "127.0.0.1:5000"
RGSTR_ADDR=:5000

# Путь к директории, где хранятся blob'ы, манифесты и upload-сессии.
RGSTR_STORAGE=./data


# ── TLS (опционально) ─────────────────────────────────────────────────────────

# Если оба параметра заданы — сервер запускается в режиме HTTPS.
# Оставьте пустыми для HTTP (например, за nginx/Caddy).
RGSTR_TLS_CERT=
RGSTR_TLS_KEY=


# ── Аутентификация ────────────────────────────────────────────────────────────

# Включить Bearer token аутентификацию.
# false — реестр открытый (подходит для локальной разработки).
# true  — все запросы требуют валидного JWT токена.
RGSTR_AUTH_ENABLED=false

# Секрет для подписи JWT (HMAC-SHA256).
# Генерация: openssl rand -hex 32
# ОБЯЗАТЕЛЬНО смените перед запуском в production!
RGSTR_AUTH_SECRET=change-me-in-production

# Полный URL токен-эндпоинта. Docker-клиент получает его из WWW-Authenticate
# заголовка и автоматически идёт за токеном при docker login / push / pull.
# Должен быть доступен клиенту извне — укажите внешний адрес сервера.
RGSTR_AUTH_REALM=http://localhost:5000/v2/auth

# Имя сервиса в токенах (поле "aud"). Должно совпадать с тем, что
# передаёт клиент в параметре ?service= при запросе токена.
RGSTR_AUTH_SERVICE=rgstr

# Издатель токенов (поле "iss"). Произвольная строка.
RGSTR_AUTH_ISSUER=rgstr

# Время жизни выданного токена.
# Формат: 30s, 15m, 1h, 24h
RGSTR_TOKEN_TTL=1h

# Список пользователей в формате "имя:bcrypt-хеш,имя:bcrypt-хеш".
# Для генерации хеша:
#   go run ./cmd/mkpasswd alice mypassword
# Bcrypt-хеши содержат символ $, который нужно экранировать в shell,
# но НЕ нужно экранировать в .env файле.
# Пример:
#   RGSTR_USERS=alice:$2a$10$abcdefghijklmnopqrstuuABCDEFGHIJKLMNOPQRSTUVWXYZ01234,bob:$2a$10$...
RGSTR_USERS=


# ── Garbage Collection ────────────────────────────────────────────────────────

# Как часто запускать сборщик мусора.
# GC удаляет blob'ы, на которые не ссылается ни один манифест,
# а также зависшие upload-сессии старше RGSTR_UPLOAD_TTL.
# Формат: 30m, 1h, 6h, 24h
RGSTR_GC_INTERVAL=1h

# Максимальное время жизни незавершённой upload-сессии.
# Сессии старше этого значения будут удалены при следующем запуске GC.
# Формат: 1h, 12h, 24h, 168h
RGSTR_UPLOAD_TTL=24h
